{
  "_meta": {
    "version": "2026-05-14",
    "scope": "Top chronic conditions, common labs, vaccines, medications, and procedures for WNY / HealtheLink agent. Each entry maps a canonical clinical term + common abbreviations + lay synonyms + brand names to the code family pulled from the matching vocabulary's data file.",
    "review_required": "STARTER CONTENT — generated from public ICD-10-CM / LOINC / CVX / RxNorm / CPT knowledge for engineering demonstration. Clinical informaticist must review code-family completeness, synonym coverage, and any subtype-specific routing before this is used in production decision-support.",
    "source": "Public CMS ICD-10-CM tabular reference, LOINC short names, CDC CVX code set, RxNorm IN/SCD names, AMA CPT category I descriptors; no proprietary terminology services consulted",
    "format": "{ vocabulary: { canonical_term: { synonyms: [...], codes: [...] } } }",
    "matching": "search_codes lowercases the query and looks up: (1) canonical key directly, then (2) any string in any synonyms[] list. First match wins; codes are returned in the listed order. Class-level entries (e.g. 'statins', 'ssri') are intentionally distinct canonicals that fan out to multiple drug codes — keep class terms OUT of individual drug entries so the class entry wins.",
    "drift_guard": "loader.py filters out synonym codes not present in the matching vocab's data file (phantom-code protection). Safe to over-list codes in a family; missing ones are silently dropped."
  },
